# The viewer is served behind Teleport and reverse-proxies /api to the orchestrator on
# the SAME origin (see nginx/default.conf.template), so Teleport's identity JWT is
# forwarded to the backend. Leave VITE_API_URL empty for same-origin requests.
VITE_API_URL=
# Shared API key sent as X-API-KEY on every request (coarse gate for GET endpoints).
# The viewer sits behind Teleport, so embedding it here is acceptable.
# Override at build time, e.g. VITE_API_KEY=xxxxx npm run build
VITE_API_KEY=
